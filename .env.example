# Copy to .env and fill in to enable live LLM mode.
# Without this, the agent runs in deterministic fallback mode (no external calls) so the repo
# is fully runnable by a reviewer with zero setup.
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
MODEL=claude-sonnet-4-6
# Confidence below this routes to a human instead of auto-sending.
AUTOSEND_THRESHOLD=0.75
